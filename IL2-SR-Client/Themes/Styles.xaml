    <!-- OverlayEquipmentPanelBrush / OverlayRaisedControlBrush / OverlayPressedControlBrush /
         OverlayRaisedBorderBrush / OverlayEdgeHighlightBrush are theme-dependent and now
         live in MilitaryPalette.xaml and MilitaryPaletteGrey.xaml so the overlay follows
         the selected theme. They are consumed below via DynamicResource. -->

    <LinearGradientBrush x:Key="OverlayDisplayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#020302" Offset="0" />
        <GradientStop Color="#080B07" Offset="0.45" />
        <GradientStop Color="#000000" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlayDisplayGlassBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#55FFFFFF" Offset="0" />
        <GradientStop Color="#20FFFFFF" Offset="0.24" />
        <GradientStop Color="#00FFFFFF" Offset="0.46" />
        <GradientStop Color="#12000000" Offset="0.74" />
        <GradientStop Color="#30000000" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlayDisplayTopReflectionBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38FFFFFF" Offset="0" />
        <GradientStop Color="#10FFFFFF" Offset="0.38" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <DrawingBrush x:Key="OverlayWeatheringTexture"
                  Opacity="0.22"
                  TileMode="Tile"
                  Viewport="0,0,24,24"
                  ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#10FFFFFF"
                                 Geometry="M 2,5 L 8,5 8,6 2,6 Z" />
                <GeometryDrawing Brush="#12000000"
                                 Geometry="M 14,2 L 22,2 22,3 14,3 Z" />
                <GeometryDrawing Brush="#0FFFFFFF"
                                 Geometry="M 5,17 L 17,17 17,18 5,18 Z" />
                <GeometryDrawing Brush="#16000000"
                                 Geometry="M 1,22 L 7,22 7,23 1,23 Z" />
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <DropShadowEffect x:Key="OverlayRaisedShadow"
                      BlurRadius="2"
                      Direction="315"
                      Opacity="0.35"
                      ShadowDepth="1"
                      Color="#000000" />

    <!-- Small slotted panel screw for overlay equipment plates -->
    <ControlTemplate x:Key="OverlayScrew" TargetType="{x:Type Control}">
        <Grid Width="6" Height="6">
            <Ellipse Style="{x:Null}"
                     Stroke="#15170F"
                     StrokeThickness="0.6">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.3">
                        <GradientStop Color="#8C8F86" Offset="0" />
                        <GradientStop Color="#54574F" Offset="0.65" />
                        <GradientStop Color="#26281F" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Rectangle Width="4.2"
                       Height="0.9"
                       Fill="#1B1E18"
                       RenderTransformOrigin="0.5,0.5"
                       Style="{x:Null}"
                       utils:ScrewSlotRandomizer.RandomAngle="True" />
        </Grid>
    </ControlTemplate>

    <!-- Equipment plate: bevelled 3D panel with weathering and corner screws.
         Wrap an overlay section in a ContentControl using this style. -->
    <Style x:Key="OverlayPlate" TargetType="{x:Type ContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid Margin="3,2,3,2">
                        <Border Background="{DynamicResource OverlayEquipmentPanelBrush}"
                                BorderBrush="#15170F"
                                BorderThickness="1"
                                CornerRadius="3"
                                Style="{x:Null}" />
                        <Border BorderBrush="{DynamicResource OverlayEdgeHighlightBrush}"
                                BorderThickness="1,1,0,0"
                                CornerRadius="3"
                                Margin="1"
                                Opacity="0.4"
                                Style="{x:Null}" />
                        <Border Background="{StaticResource OverlayWeatheringTexture}"
                                CornerRadius="3"
                                IsHitTestVisible="False"
                                Style="{x:Null}" />
                        <Rectangle RadiusX="3"
                                   RadiusY="3"
                                   IsHitTestVisible="False"
                                   utils:PanelWeathering.Enabled="True" />
                        <ContentPresenter Margin="9,5,9,5" />
                        <Control Template="{StaticResource OverlayScrew}"
                                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2.5" />
                        <Control Template="{StaticResource OverlayScrew}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2.5" />
                        <Control Template="{StaticResource OverlayScrew}"
                                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2.5" />
                        <Control Template="{StaticResource OverlayScrew}"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2.5" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OverlaySliderRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OverlaySliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{DynamicResource OverlayRaisedControlBrush}"
                            BorderBrush="{DynamicResource OverlayRaisedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Style="{x:Null}">
                        <Border BorderBrush="{DynamicResource OverlayEdgeHighlightBrush}"
                                BorderThickness="1,1,0,0"
                                CornerRadius="2"
                                Opacity="0.45"
                                Style="{x:Null}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OverlaySlider" TargetType="{x:Type Slider}">
        <Setter Property="Height" Value="18" />
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid Height="{TemplateBinding Height}">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                Background="#81909A"
                                BorderBrush="#4C565C"
                                BorderThickness="1"
                                Style="{x:Null}">
                            <Border BorderBrush="#B8C2C8"
                                    BorderThickness="0,1,0,0"
                                    Opacity="0.35"
                                    Style="{x:Null}" />
                        </Border>
                        <Track x:Name="PART_Track"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Style="{StaticResource OverlaySliderRepeatButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Style="{StaticResource OverlaySliderRepeatButton}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource OverlaySliderThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

