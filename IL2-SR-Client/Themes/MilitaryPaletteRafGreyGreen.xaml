<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- RAF cockpit grey-green variant: muted interior green paint, cream stencilling,
         dark instrument wells, and dull steel fittings. Key set must stay identical
         to MilitaryPalette.xaml. -->
    <Color x:Key="MilWindowBackgroundColor">#4C5547</Color>
    <Color x:Key="MilChromeColor">#3B4338</Color>
    <Color x:Key="MilWellColor">#20261F</Color>
    <Color x:Key="MilBorderColor">#6A745E</Color>
    <Color x:Key="MilTextPrimaryColor">#F0E8C9</Color>
    <Color x:Key="MilTextSecondaryColor">#B7B99B</Color>
    <Color x:Key="MilAccentColor">#D8C37A</Color>
    <Color x:Key="MilActionColor">#687057</Color>
    <Color x:Key="MilActionBorderColor">#8A8F68</Color>
    <Color x:Key="MilActionHoverColor">#747D61</Color>
    <Color x:Key="MilLedOnColor">#4FE34F</Color>
    <Color x:Key="MilLedOffColor">#4C5548</Color>
    <Color x:Key="MilLedErrorColor">#C95545</Color>
    <Color x:Key="MilRowAltColor">#424B3E</Color>

    <!-- dull aluminium and primer showing through worn cockpit paint -->
    <Color x:Key="MilWornMetal1Color">#9AA091</Color>
    <Color x:Key="MilWornMetal2Color">#AEB4A6</Color>
    <Color x:Key="MilWornMetal3Color">#C2C7B8</Color>

    <SolidColorBrush x:Key="MilWindowBackgroundBrush" Color="{StaticResource MilWindowBackgroundColor}" />
    <SolidColorBrush x:Key="MilChromeBrush" Color="{StaticResource MilChromeColor}" />
    <SolidColorBrush x:Key="MilWellBrush" Color="{StaticResource MilWellColor}" />
    <SolidColorBrush x:Key="MilBorderBrush" Color="{StaticResource MilBorderColor}" />
    <SolidColorBrush x:Key="MilTextPrimaryBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="MilTextSecondaryBrush" Color="{StaticResource MilTextSecondaryColor}" />
    <SolidColorBrush x:Key="MilAccentBrush" Color="{StaticResource MilAccentColor}" />
    <SolidColorBrush x:Key="MilActionBrush" Color="{StaticResource MilActionColor}" />
    <SolidColorBrush x:Key="MilActionBorderBrush" Color="{StaticResource MilActionBorderColor}" />
    <SolidColorBrush x:Key="MilActionHoverBrush" Color="{StaticResource MilActionHoverColor}" />
    <SolidColorBrush x:Key="MilLedOnBrush" Color="{StaticResource MilLedOnColor}" />
    <SolidColorBrush x:Key="MilLedOffBrush" Color="{StaticResource MilLedOffColor}" />
    <SolidColorBrush x:Key="MilLedErrorBrush" Color="{StaticResource MilLedErrorColor}" />
    <SolidColorBrush x:Key="MilRowAltBrush" Color="{StaticResource MilRowAltColor}" />
    <SolidColorBrush x:Key="MilVuFaceBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="MilVuMarkBrush" Color="#2A251C" />
    <SolidColorBrush x:Key="MilVuNeedleBrush" Color="#D33124" />
    <SolidColorBrush x:Key="OverlayTxRxLabelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OverlayChannelButtonForegroundBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="OverlayChannelButtonSelectedForegroundBrush" Color="{StaticResource MilTextPrimaryColor}" />

    <FontFamily x:Key="MilFontStencil">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Allerta Stencil</FontFamily>
    <FontFamily x:Key="MilFontMono">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Share Tech Mono</FontFamily>

    <LinearGradientBrush x:Key="MilPanelFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#58624F" />
        <GradientStop Offset="1" Color="#414A3D" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MilBtnDarkFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#66705A" />
        <GradientStop Offset="1" Color="#3F483A" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#737D66" />
        <GradientStop Offset="1" Color="#4B5546" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#353D32" />
        <GradientStop Offset="1" Color="#566049" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MilBtnBrassFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#9C9664" />
        <GradientStop Offset="1" Color="#6F6B45" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#ADA675" />
        <GradientStop Offset="1" Color="#7C7750" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#5E5A38" />
        <GradientStop Offset="1" Color="#8E895E" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="MilScrewBrush" GradientOrigin="0.35,0.3">
        <GradientStop Offset="0" Color="#C2C7B8" />
        <GradientStop Offset="0.6" Color="#747A68" />
        <GradientStop Offset="1" Color="#30362D" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="MilLampBezelBrush" GradientOrigin="0.3,0.25">
        <GradientStop Offset="0" Color="#8C927B" />
        <GradientStop Offset="0.7" Color="#4B5346" />
        <GradientStop Offset="1" Color="#171D16" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="MilLampGlassBrush" GradientOrigin="0.3,0.25" Center="0.3,0.25" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Offset="0" Color="#90FFF6DC" />
        <GradientStop Offset="0.45" Color="#20FFF6DC" />
        <GradientStop Offset="1" Color="#00FFF6DC" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="OverlayEquipmentPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#58624F" Offset="0" />
        <GradientStop Color="#4A5345" Offset="0.45" />
        <GradientStop Color="#3C4538" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayRaisedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#69735E" Offset="0" />
        <GradientStop Color="#59624F" Offset="0.52" />
        <GradientStop Color="#424B3E" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayPressedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#333B30" Offset="0" />
        <GradientStop Color="#566049" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlayRaisedBorderBrush" Color="#171D16" />
    <SolidColorBrush x:Key="OverlayEdgeHighlightBrush" Color="#929980" />

    <LinearGradientBrush x:Key="OverlayAccentRaisedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D8C37A" Offset="0" />
        <GradientStop Color="#BCA862" Offset="0.52" />
        <GradientStop Color="#7E7545" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlayAccentRaisedBorderBrush" Color="#3B351F" />

</ResourceDictionary>


