<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ivory instrument-panel variant: aged cream enamel, dark engraved text,
         warm brass fittings. Key set must stay identical to MilitaryPalette.xaml. -->
    <Color x:Key="MilWindowBackgroundColor">#D8CFB8</Color>
    <Color x:Key="MilChromeColor">#B9AE95</Color>
    <Color x:Key="MilWellColor">#F0E7CF</Color>
    <Color x:Key="MilBorderColor">#7A6848</Color>
    <Color x:Key="MilTextPrimaryColor">#2E2618</Color>
    <Color x:Key="MilTextSecondaryColor">#6C5E43</Color>
    <Color x:Key="MilAccentColor">#735A24</Color>
    <Color x:Key="MilActionColor">#C8B27A</Color>
    <Color x:Key="MilActionBorderColor">#7D6630</Color>
    <Color x:Key="MilActionHoverColor">#D4C08C</Color>
    <Color x:Key="MilLedOnColor">#36C944</Color>
    <Color x:Key="MilLedOffColor">#736C5F</Color>
    <Color x:Key="MilLedErrorColor">#B64535</Color>
    <Color x:Key="MilRowAltColor">#CFC3AA</Color>

    <!-- worn brass and rubbed enamel showing through weathering -->
    <Color x:Key="MilWornMetal1Color">#8A764F</Color>
    <Color x:Key="MilWornMetal2Color">#A39066</Color>
    <Color x:Key="MilWornMetal3Color">#BBA878</Color>

    <SolidColorBrush x:Key="MilWindowBackgroundBrush" Color="{StaticResource MilWindowBackgroundColor}" />
    <SolidColorBrush x:Key="MilChromeBrush" Color="{StaticResource MilChromeColor}" />
    <SolidColorBrush x:Key="MilWellBrush" Color="{StaticResource MilWellColor}" />
    <SolidColorBrush x:Key="MilBorderBrush" Color="{StaticResource MilBorderColor}" />
    <SolidColorBrush x:Key="MilTextPrimaryBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="MilTextSecondaryBrush" Color="{StaticResource MilTextSecondaryColor}" />
    <SolidColorBrush x:Key="MilAccentBrush" Color="{StaticResource MilAccentColor}" />
    <SolidColorBrush x:Key="MilActionBrush" Color="{StaticResource MilActionColor}" />
    <SolidColorBrush x:Key="MilActionBorderBrush" Color="{StaticResource MilActionBorderColor}" />
    <SolidColorBrush x:Key="MilActionHoverBrush" Color="{StaticResource MilActionHoverColor}" />
    <SolidColorBrush x:Key="MilLedOnBrush" Color="{StaticResource MilLedOnColor}" />
    <SolidColorBrush x:Key="MilLedOffBrush" Color="{StaticResource MilLedOffColor}" />
    <SolidColorBrush x:Key="MilLedErrorBrush" Color="{StaticResource MilLedErrorColor}" />
    <SolidColorBrush x:Key="MilRowAltBrush" Color="{StaticResource MilRowAltColor}" />
    <SolidColorBrush x:Key="MilVuFaceBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="MilVuMarkBrush" Color="#F3E7C8" />
    <SolidColorBrush x:Key="MilVuNeedleBrush" Color="#D33124" />
    <SolidColorBrush x:Key="OverlayTxRxLabelBrush" Color="#000000" />
    <SolidColorBrush x:Key="OverlayChannelButtonForegroundBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="OverlayChannelButtonSelectedForegroundBrush" Color="{StaticResource MilTextPrimaryColor}" />

    <FontFamily x:Key="MilFontStencil">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Allerta Stencil</FontFamily>
    <FontFamily x:Key="MilFontMono">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Share Tech Mono</FontFamily>

    <LinearGradientBrush x:Key="MilPanelFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#E7DDC4" />
        <GradientStop Offset="1" Color="#CFC2A7" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MilBtnDarkFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#D8C792" />
        <GradientStop Offset="1" Color="#AE9561" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#E3D39E" />
        <GradientStop Offset="1" Color="#BFA773" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#9B814B" />
        <GradientStop Offset="1" Color="#C8B27A" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MilBtnBrassFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#D2B767" />
        <GradientStop Offset="1" Color="#A88638" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#E0C779" />
        <GradientStop Offset="1" Color="#B69343" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#8E6F2A" />
        <GradientStop Offset="1" Color="#C0A154" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="MilScrewBrush" GradientOrigin="0.35,0.3">
        <GradientStop Offset="0" Color="#E1D3AE" />
        <GradientStop Offset="0.6" Color="#8B7650" />
        <GradientStop Offset="1" Color="#3B321F" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="MilLampBezelBrush" GradientOrigin="0.3,0.25">
        <GradientStop Offset="0" Color="#B9A977" />
        <GradientStop Offset="0.7" Color="#75613A" />
        <GradientStop Offset="1" Color="#2D2413" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="MilLampGlassBrush" GradientOrigin="0.3,0.25" Center="0.3,0.25" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Offset="0" Color="#90FFFFFF" />
        <GradientStop Offset="0.45" Color="#25FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="OverlayEquipmentPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E2D7BE" Offset="0" />
        <GradientStop Color="#D5C8AD" Offset="0.45" />
        <GradientStop Color="#C5B799" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayRaisedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D4C389" Offset="0" />
        <GradientStop Color="#BCA36D" Offset="0.52" />
        <GradientStop Color="#9E8450" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayPressedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#8A6F3B" Offset="0" />
        <GradientStop Color="#C3AF7A" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlayRaisedBorderBrush" Color="#5E4B27" />
    <SolidColorBrush x:Key="OverlayEdgeHighlightBrush" Color="#FFF1C4" />

    <LinearGradientBrush x:Key="OverlayAccentRaisedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E6CA73" Offset="0" />
        <GradientStop Color="#CDAA4E" Offset="0.52" />
        <GradientStop Color="#92712B" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlayAccentRaisedBorderBrush" Color="#5E4313" />

</ResourceDictionary>

