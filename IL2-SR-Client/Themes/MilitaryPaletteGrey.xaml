<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Grey instrument-panel variant of the vintage palette: blue-grey metal
         (RLM 66 schwarzgrau), aged cream lettering, steel fittings. Selected via
         the Theme setting; MilitaryPalette.xaml (bakelite) is the default.
         Key set must stay identical to MilitaryPalette.xaml. -->
    <Color x:Key="MilWindowBackgroundColor">#393D3F</Color>
    <Color x:Key="MilChromeColor">#2B2E30</Color>
    <Color x:Key="MilWellColor">#1F2224</Color>
    <Color x:Key="MilBorderColor">#51565A</Color>
    <Color x:Key="MilTextPrimaryColor">#E4E1D3</Color>
    <Color x:Key="MilTextSecondaryColor">#8E9290</Color>
    <Color x:Key="MilAccentColor">#CCC6A9</Color>
    <Color x:Key="MilActionColor">#4D5357</Color>
    <Color x:Key="MilActionBorderColor">#6C7378</Color>
    <Color x:Key="MilActionHoverColor">#5A6165</Color>
    <Color x:Key="MilLedOnColor">#4FE34F</Color>
    <Color x:Key="MilLedOffColor">#43474A</Color>
    <Color x:Key="MilLedErrorColor">#C25B4E</Color>
    <Color x:Key="MilRowAltColor">#313538</Color>

    <!-- bare metal showing through worn paint -->
    <Color x:Key="MilWornMetal1Color">#9DA1A4</Color>
    <Color x:Key="MilWornMetal2Color">#ACB0B2</Color>
    <Color x:Key="MilWornMetal3Color">#BCC0C2</Color>

    <SolidColorBrush x:Key="MilWindowBackgroundBrush" Color="{StaticResource MilWindowBackgroundColor}" />
    <SolidColorBrush x:Key="MilChromeBrush" Color="{StaticResource MilChromeColor}" />
    <SolidColorBrush x:Key="MilWellBrush" Color="{StaticResource MilWellColor}" />
    <SolidColorBrush x:Key="MilBorderBrush" Color="{StaticResource MilBorderColor}" />
    <SolidColorBrush x:Key="MilTextPrimaryBrush" Color="{StaticResource MilTextPrimaryColor}" />
    <SolidColorBrush x:Key="MilTextSecondaryBrush" Color="{StaticResource MilTextSecondaryColor}" />
    <SolidColorBrush x:Key="MilAccentBrush" Color="{StaticResource MilAccentColor}" />
    <SolidColorBrush x:Key="MilActionBrush" Color="{StaticResource MilActionColor}" />
    <SolidColorBrush x:Key="MilActionBorderBrush" Color="{StaticResource MilActionBorderColor}" />
    <SolidColorBrush x:Key="MilActionHoverBrush" Color="{StaticResource MilActionHoverColor}" />
    <SolidColorBrush x:Key="MilLedOnBrush" Color="{StaticResource MilLedOnColor}" />
    <SolidColorBrush x:Key="MilLedOffBrush" Color="{StaticResource MilLedOffColor}" />
    <SolidColorBrush x:Key="MilLedErrorBrush" Color="{StaticResource MilLedErrorColor}" />
    <SolidColorBrush x:Key="MilRowAltBrush" Color="{StaticResource MilRowAltColor}" />

    <FontFamily x:Key="MilFontStencil">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Allerta Stencil</FontFamily>
    <FontFamily x:Key="MilFontMono">pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Share Tech Mono</FontFamily>

    <!-- ===== Skeuomorphic surfaces: equipment plates, pushbuttons, screws, lamps ===== -->

    <!-- Raised equipment plate face -->
    <LinearGradientBrush x:Key="MilPanelFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#45494C" />
        <GradientStop Offset="1" Color="#34383B" />
    </LinearGradientBrush>

    <!-- Dark metal pushbutton (default buttons) -->
    <LinearGradientBrush x:Key="MilBtnDarkFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#4D5256" />
        <GradientStop Offset="1" Color="#303437" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#5A6064" />
        <GradientStop Offset="1" Color="#3A3E41" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnDarkPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#282C2E" />
        <GradientStop Offset="1" Color="#3E4346" />
    </LinearGradientBrush>

    <!-- Steel pushbutton (primary actions / lit toggles) -->
    <LinearGradientBrush x:Key="MilBtnBrassFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#757C81" />
        <GradientStop Offset="1" Color="#4F555A" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#828A8F" />
        <GradientStop Offset="1" Color="#585F64" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MilBtnBrassPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#474D52" />
        <GradientStop Offset="1" Color="#666D73" />
    </LinearGradientBrush>

    <!-- Slotted panel screw -->
    <RadialGradientBrush x:Key="MilScrewBrush" GradientOrigin="0.35,0.3">
        <GradientStop Offset="0" Color="#C0BCAD" />
        <GradientStop Offset="0.6" Color="#5F6266" />
        <GradientStop Offset="1" Color="#2C2F31" />
    </RadialGradientBrush>

    <!-- Indicator lamp bezel ring and glass specular highlight -->
    <RadialGradientBrush x:Key="MilLampBezelBrush" GradientOrigin="0.3,0.25">
        <GradientStop Offset="0" Color="#84817A" />
        <GradientStop Offset="0.7" Color="#3D4043" />
        <GradientStop Offset="1" Color="#17191B" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="MilLampGlassBrush" GradientOrigin="0.3,0.25" Center="0.3,0.25" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Offset="0" Color="#90FFFFFF" />
        <GradientStop Offset="0.45" Color="#20FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </RadialGradientBrush>

    <!-- ===== Radio overlay equipment surfaces (grey). Mirrored in
         MilitaryPalette.xaml so the overlay follows the selected theme. ===== -->
    <LinearGradientBrush x:Key="OverlayEquipmentPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#494D50" Offset="0" />
        <GradientStop Color="#3C4043" Offset="0.45" />
        <GradientStop Color="#303437" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayRaisedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5E6367" Offset="0" />
        <GradientStop Color="#4B5054" Offset="0.52" />
        <GradientStop Color="#3A3E41" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="OverlayPressedControlBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#282C2E" Offset="0" />
        <GradientStop Color="#3E4346" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OverlayRaisedBorderBrush" Color="#17191B" />
    <SolidColorBrush x:Key="OverlayEdgeHighlightBrush" Color="#828A8F" />

</ResourceDictionary>
