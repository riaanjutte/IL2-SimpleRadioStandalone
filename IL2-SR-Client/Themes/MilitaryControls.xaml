<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.Utils.ValueConverters"
                    xmlns:utils="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.Utils">

    <!-- The Mil* palette is intentionally NOT merged here. The active palette
         (MilitaryPalette.xaml or MilitaryPaletteGrey.xaml, per the Theme setting)
         is merged into Application.Resources at startup, and StaticResource
         lookups in this dictionary fall through to application resources. -->

    <converters:StringToUpperConverter x:Key="MilUpperConverter" />

    <!-- ============ Labels & text ============ -->
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ============ Buttons: physical pushbuttons (dark rim, bevelled gradient face) ============ -->
    <Style x:Key="MilButtonBase" TargetType="{x:Type ButtonBase}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource MilBtnDarkFaceBrush}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border x:Name="Rim"
                            Background="{DynamicResource ThreeDDarkRimBrush}"
                            CornerRadius="4"
                            Padding="1">
                        <Border x:Name="Face"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ThreeDHighlightBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Face" Property="BorderThickness" Value="1,0,1,1" />
                            <Setter TargetName="Face" Property="BorderBrush" Value="{DynamicResource ThreeDSoftHighlightBrush}" />
                            <Setter TargetName="Content" Property="Margin" Value="0,1,0,-1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#B8AD94" />
                            <Setter TargetName="Rim" Property="Background" Value="#100D08" />
                            <Setter TargetName="Face" Property="Background" Value="#262117" />
                            <Setter TargetName="Face" Property="BorderBrush" Value="#4B4537" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource MilBtnDarkHoverBrush}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="True" />
                    <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource MilBtnDarkPressedBrush}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MilButtonBase}" />

    <!-- Primary action style. MainWindow buttons reference SquareButtonStyle (a MahApps key)
         via DynamicResource; defining the same key here makes those buttons pick up the
         military action look with zero per-button XAML edits. -->
    <Style x:Key="SquareButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MilButtonBase}">
        <Setter Property="Background" Value="{DynamicResource MilBtnBrassFaceBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource MilFontMono}" />
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource MilBtnBrassHoverBrush}" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="True" />
                    <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource MilBtnBrassPressedBrush}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ToggleButton (ON/OFF settings switches): lit brass when engaged ============ -->
    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource MilButtonBase}">
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="FontFamily" Value="{StaticResource MilFontMono}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MilBtnDarkHoverBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource MilBtnBrassFaceBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource MilBtnDarkPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ TextBox: inset well with inner top shadow ============ -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource MilWellBrush}" />
        <Setter Property="BorderBrush" Value="#120D07" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CaretBrush" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource MilAccentBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <Grid>
                            <Border Height="2"
                                    Margin="1,1,1,0"
                                    VerticalAlignment="Top"
                                    Background="#40000000"
                                    CornerRadius="1"
                                    Opacity="{DynamicResource ThreeDEffectOpacity}" />
                            <Border Height="1"
                                    Margin="1,0,1,1"
                                    VerticalAlignment="Bottom"
                                    Background="#14FFF6DC"
                                    Opacity="{DynamicResource ThreeDEffectOpacity}" />
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource MilAccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#B8AD94" />
                <Setter Property="Background" Value="#211D16" />
                <Setter Property="BorderBrush" Value="#4B4537" />
                <Setter Property="CaretBrush" Value="#B8AD94" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ComboBox ============ -->
    <Style x:Key="MilComboToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Bd"
                            Background="{DynamicResource MilWellBrush}"
                            BorderBrush="{DynamicResource MilBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Path x:Name="Arrow"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="{DynamicResource MilAccentBrush}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource MilAccentBrush}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#211D16" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#4B4537" />
                            <Setter TargetName="Arrow" Property="Fill" Value="#6B6251" />
                            <Setter TargetName="Arrow" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource MilWellBrush}" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource MilComboToggle}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <ContentPresenter x:Name="ContentSite"
                                          Margin="6,2,22,2"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          IsHitTestVisible="False" />
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="{DynamicResource MilWellBrush}"
                                        BorderBrush="{DynamicResource MilBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#B8AD94" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MilActionBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ CheckBox ============ -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                VerticalAlignment="Center"
                                Background="{DynamicResource MilWellBrush}"
                                BorderBrush="{DynamicResource MilBorderBrush}"
                                BorderThickness="1">
                            <Path x:Name="Check"
                                  Data="M 2 7 L 6 11 L 12 3"
                                  Stroke="{DynamicResource MilAccentBrush}"
                                  StrokeThickness="2"
                                  Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource MilAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ RadioButton ============ -->
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid VerticalAlignment="Center">
                            <Ellipse x:Name="Outer"
                                     Width="14" Height="14"
                                     Fill="{DynamicResource MilWellBrush}"
                                     Stroke="{DynamicResource MilBorderBrush}"
                                     StrokeThickness="1" />
                            <Ellipse x:Name="Dot"
                                     Width="6" Height="6"
                                     Fill="{DynamicResource MilAccentBrush}"
                                     Visibility="Collapsed" />
                        </Grid>
                        <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource MilAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Slider (horizontal only; the app has no vertical sliders in MainWindow) ============ -->
    <Style x:Key="MilSliderRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Fill="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MilSliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{DynamicResource OverlayAccentRaisedBrush}"
                            BorderBrush="{DynamicResource OverlayAccentRaisedBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Border BorderBrush="{DynamicResource OverlayEdgeHighlightBrush}"
                                BorderThickness="1,1,0,0"
                                CornerRadius="2"
                                Opacity="{DynamicResource ThreeDEffectOpacity}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Slider}">
        <Setter Property="Height" Value="26" />
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid Height="{TemplateBinding Height}" Background="Transparent">
                        <Border Height="4"
                                VerticalAlignment="Center"
                                Background="{DynamicResource OverlayAccentRaisedBrush}"
                                BorderBrush="{DynamicResource OverlayAccentRaisedBorderBrush}"
                                BorderThickness="1">
                            <Border BorderBrush="{DynamicResource OverlayEdgeHighlightBrush}"
                                    BorderThickness="0,1,0,0"
                                    Opacity="0.55" />
                        </Border>
                        <Track x:Name="PART_Track"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                              Command="Slider.DecreaseLarge" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                              Command="Slider.IncreaseLarge" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MilSliderThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slotted panel screw (shared by plates and meters) -->
    <ControlTemplate x:Key="MilPanelScrew" TargetType="{x:Type Control}">
        <Grid Width="10.125" Height="10.125">
            <Ellipse Fill="{DynamicResource MilScrewBrush}"
                     Stroke="#15100A"
                     StrokeThickness="0.9" />
            <Rectangle Width="7.3125"
                       Height="1.35"
                       Fill="#241F14"
                       RenderTransformOrigin="0.5,0.5"
                       utils:ScrewSlotRandomizer.RandomAngle="True" />
        </Grid>
    </ControlTemplate>

    <!-- ============ ProgressBar: analog VU dial (needle meter) ============ -->
    <converters:VuNeedleAngleConverter x:Key="MilVuNeedleConverter" />

    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="150" Height="80">
                            <!-- bezel -->
                            <Border Background="#15100A" CornerRadius="6" />
                            <!-- ivory face -->
                            <Border Margin="3"
                                    Background="{DynamicResource MilVuFaceBrush}"
                                    CornerRadius="4" />
                            <Canvas>
                                <!-- scale arc -->
                                <Path Data="M 32.4,42.2 A 52,52 0 0 1 117.6,42.2"
                                      Stroke="{DynamicResource MilVuMarkBrush}"
                                      StrokeThickness="2" />
                                <!-- overload zone (0 dB onward) -->
                                <Path Data="M 94.5,23.8 A 52,52 0 0 1 117.6,42.2"
                                      Stroke="{DynamicResource MilLedErrorBrush}"
                                      StrokeThickness="3" />
                                <!-- major ticks -->
                                <Line X1="32.4" Y1="42.2" X2="37.3" Y2="45.6" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1.5" />
                                <Line X1="46.7" Y1="28.4" X2="49.9" Y2="33.4" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1.5" />
                                <Line X1="61.5" Y1="21.8" X2="63.1" Y2="27.6" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1.5" />
                                <Line X1="94.5" Y1="23.8" X2="92.2" Y2="29.4" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1.5" />
                                <Line X1="117.6" Y1="42.2" X2="112.7" Y2="45.6" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1.5" />
                                <!-- minor ticks -->
                                <Line X1="38.9" Y1="34.6" X2="41.3" Y2="37.1" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1" />
                                <Line X1="53.8" Y1="24.5" X2="55.2" Y2="27.7" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1" />
                                <Line X1="78.2" Y1="20.1" X2="78.0" Y2="23.6" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1" />
                                <Line X1="107.3" Y1="31.3" X2="105.2" Y2="34.0" Stroke="{DynamicResource MilVuMarkBrush}" StrokeThickness="1" />
                                <!-- dB figures -->
                                <TextBlock Canvas.Left="17" Canvas.Top="31"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="8"
                                           Foreground="{DynamicResource MilVuMarkBrush}"
                                           Text="-20" />
                                <TextBlock Canvas.Left="35" Canvas.Top="14"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="8"
                                           Foreground="{DynamicResource MilVuMarkBrush}"
                                           Text="-10" />
                                <TextBlock Canvas.Left="55" Canvas.Top="7"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="8"
                                           Foreground="{DynamicResource MilVuMarkBrush}"
                                           Text="-5" />
                                <TextBlock Canvas.Left="95" Canvas.Top="9"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="8"
                                           Foreground="{DynamicResource MilVuMarkBrush}"
                                           Text="0" />
                                <TextBlock Canvas.Left="119" Canvas.Top="31"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="8"
                                           Foreground="{DynamicResource MilLedErrorBrush}"
                                           Text="+3" />
                                <TextBlock Canvas.Left="66" Canvas.Top="44"
                                           FontFamily="{StaticResource MilFontMono}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource MilVuMarkBrush}"
                                           Text="VU" />
                                <!-- needle -->
                                <Line X1="75" Y1="72" X2="75" Y2="23"
                                      Stroke="{DynamicResource MilVuNeedleBrush}"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="2">
                                    <Line.RenderTransform>
                                        <RotateTransform CenterX="75" CenterY="72">
                                            <RotateTransform.Angle>
                                                <MultiBinding Converter="{StaticResource MilVuNeedleConverter}">
                                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                </MultiBinding>
                                            </RotateTransform.Angle>
                                        </RotateTransform>
                                    </Line.RenderTransform>
                                </Line>
                                <!-- needle hub -->
                                <Ellipse Canvas.Left="70" Canvas.Top="67"
                                         Width="10" Height="10"
                                         Fill="{DynamicResource MilVuNeedleBrush}" />
                            </Canvas>
                            <!-- glossy glass cover: bright curved band on top, curvature
                                 shadow below; white alone vanishes on the ivory face, so
                                 the read comes from the band edge and the dark shading -->
                            <Grid Margin="3"
                                  Opacity="{DynamicResource ThreeDGlassOpacity}">
                                <Grid.Clip>
                                    <RectangleGeometry RadiusX="4"
                                                       RadiusY="4"
                                                       Rect="0,0,144,74" />
                                </Grid.Clip>
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#00000000" />
                                            <GradientStop Offset="0.5" Color="#08000000" />
                                            <GradientStop Offset="1" Color="#2E000000" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Path Data="M 0,0 L 144,0 L 144,24 Q 72,56 0,24 Z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#96FFFFFF" />
                                            <GradientStop Offset="1" Color="#22FFFFFF" />
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                                <Path Data="M 144,24 Q 72,56 0,24"
                                      Stroke="#78FFFFFF"
                                      StrokeThickness="1" />
                            </Grid>
                            <!-- bezel corner screws -->
                            <Control Template="{StaticResource MilPanelScrew}"
                                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,6,0,0"
                                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
                            <Control Template="{StaticResource MilPanelScrew}"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0"
                                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
                            <Control Template="{StaticResource MilPanelScrew}"
                                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6,0,0,6"
                                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
                            <Control Template="{StaticResource MilPanelScrew}"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
                        </Grid>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ GroupBox: riveted equipment plate with corner screws ============ -->
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,5,0,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Border Background="{DynamicResource MilPanelFaceBrush}"
                            BorderBrush="#15100A"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Border BorderBrush="{DynamicResource ThreeDSoftHighlightBrush}"
                                BorderThickness="1,1,0,0"
                                CornerRadius="5">
                            <Grid>
                                <!-- procedural wear: scratches, scuffs, edge grime -->
                                <Rectangle RadiusX="5"
                                           RadiusY="5"
                                           Opacity="{DynamicResource WeatheringOpacity}"
                                           utils:PanelWeathering.Enabled="True" />
                                <Rectangle RadiusX="5"
                                           RadiusY="5"
                                           Opacity="{DynamicResource WeatheringExtraOpacity}"
                                           utils:PanelWeathering.Enabled="True" />

                                <!-- corner screws -->
                                <Control Template="{StaticResource MilPanelScrew}"
                                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,5,0,0"
                                         Opacity="{DynamicResource ThreeDScrewOpacity}" />
                                <Control Template="{StaticResource MilPanelScrew}"
                                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0"
                                         Opacity="{DynamicResource ThreeDScrewOpacity}" />
                                <Control Template="{StaticResource MilPanelScrew}"
                                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="5,0,0,5"
                                         Opacity="{DynamicResource ThreeDScrewOpacity}" />
                                <Control Template="{StaticResource MilPanelScrew}"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                         Opacity="{DynamicResource ThreeDScrewOpacity}" />

                                <DockPanel Margin="20,6,20,10">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,2,0,6" LastChildFill="True">
                                        <ContentPresenter DockPanel.Dock="Left"
                                                          ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{DynamicResource MilAccentBrush}"
                                                          TextElement.FontFamily="{StaticResource MilFontStencil}"
                                                          TextElement.FontSize="14">
                                            <ContentPresenter.Effect>
                                                <DropShadowEffect BlurRadius="0"
                                                                  Direction="270"
                                                                  Opacity="{DynamicResource ThreeDEffectOpacity}"
                                                                  ShadowDepth="1"
                                                                  Color="#000000" />
                                            </ContentPresenter.Effect>
                                        </ContentPresenter>
                                        <StackPanel Margin="10,2,0,0" VerticalAlignment="Center">
                                            <Border Height="1" Background="#15100A" />
                                            <Border Height="1" Background="{DynamicResource ThreeDSoftHighlightBrush}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <ContentPresenter Margin="2,0,2,2" />
                                </DockPanel>
                            </Grid>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Tabs ============ -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource MilWindowBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextSecondaryBrush}" />
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock FontFamily="{StaticResource MilFontStencil}"
                               FontSize="16"
                               Text="{Binding Converter={StaticResource MilUpperConverter}}"
                               TextWrapping="NoWrap" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="Rim"
                            Background="#15100A"
                            CornerRadius="4,4,0,0"
                            Margin="0,3,3,0"
                            Padding="1,1,1,0">
                        <Border x:Name="Face"
                                Background="{DynamicResource MilBtnDarkFaceBrush}"
                                BorderBrush="{DynamicResource ThreeDHighlightBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="3,3,0,0"
                                Padding="12,5">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="9"
                                      Height="9"
                                      Margin="0,0,7,0"
                                      VerticalAlignment="Center">
                                    <Ellipse Fill="{DynamicResource MilLampBezelBrush}" />
                                    <Ellipse x:Name="Lamp"
                                             Margin="1.5"
                                             Fill="{DynamicResource MilLedOffBrush}" />
                                    <Ellipse Margin="1.5" Fill="{DynamicResource MilLampGlassBrush}" />
                                </Grid>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Rim" Property="Margin" Value="0,0,3,0" />
                            <Setter TargetName="Face" Property="Background" Value="{DynamicResource MilPanelFaceBrush}" />
                            <Setter TargetName="Lamp" Property="Fill" Value="{DynamicResource MilLedOnBrush}" />
                            <Setter TargetName="Lamp" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="7"
                                                      ShadowDepth="0"
                                                      Opacity="{DynamicResource ThreeDEffectOpacity}"
                                                      Color="#4FE34F" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
                            <Setter TargetName="Face" Property="Background" Value="{DynamicResource MilBtnDarkHoverBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ScrollBar ============ -->
    <Style x:Key="MilScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{DynamicResource MilBorderBrush}" CornerRadius="3" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="Width" Value="9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Border Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                              Command="ScrollBar.PageUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                              Command="ScrollBar.PageDownCommand" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MilScrollThumb}" Margin="1" />
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="9" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                                      Command="ScrollBar.PageLeftCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource MilSliderRepeatButton}"
                                                      Command="ScrollBar.PageRightCommand" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource MilScrollThumb}" Margin="1" />
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ToolTip ============ -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ============ DataGrid (FavouriteServersView renders inside MainWindow) ============ -->
    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource MilWindowBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{DynamicResource MilWellBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource MilRowAltBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MilAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontFamily" Value="{StaticResource MilFontMono}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,2" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource MilActionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Row-header gutter: dark instead of the default light strip -->
    <Style TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Background" Value="{DynamicResource MilChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridRowHeader}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
