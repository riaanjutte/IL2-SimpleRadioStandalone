<controls:MetroWindow x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.ClientList.ClientListWindow"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      Title="Connected Clients"
                      MinWidth="300"
                            MinHeight="390"
                      Width="300"
                      Height="390"
                      ResizeMode="CanResizeWithGrip"
                      Background="{StaticResource MilWindowBackgroundBrush}"
                      Foreground="{StaticResource MilTextPrimaryBrush}"
                      FontSize="12"
                      WindowTitleBrush="{StaticResource MilChromeBrush}"
                      NonActiveWindowTitleBrush="{StaticResource MilChromeBrush}"
                      GlowBrush="{StaticResource MilBorderBrush}"
                      NonActiveGlowBrush="{StaticResource MilChromeBrush}"
                      TitleCharacterCasing="Upper"
                      xmlns:clients="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.ClientList"
                     >
    <controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IL2-SR-ClientRadio;component/Themes/MilitaryControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:MetroWindow.Resources>

    <controls:MetroWindow.TitleTemplate>
        <DataTemplate>
            <TextBlock Margin="8,0,8,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource MilFontStencil}"
                       FontSize="14"
                       Text="{Binding Converter={StaticResource MilUpperConverter}}" />
        </DataTemplate>
    </controls:MetroWindow.TitleTemplate>

    <GroupBox Header="Roster" Margin="6,2,6,6">
        <ListBox Name="ClientList"
                 HorizontalContentAlignment="Stretch"
                 Padding="5"
                 Background="{StaticResource MilWellBrush}"
                 Foreground="{StaticResource MilTextPrimaryBrush}"
                 BorderBrush="{StaticResource MilBorderBrush}"
                 BorderThickness="1"
                 FontFamily="{StaticResource MilFontMono}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource MilTextPrimaryBrush}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource MilRowAltBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource MilActionBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*" />
                            <ColumnDefinition Width="0.5*" />
                            <ColumnDefinition Width="0.5*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}"  Grid.Column="0" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Channel}"  Grid.Column="1" />

                        <!-- coalition jewel lamp -->
                        <Grid Width="14"
                              Height="14"
                              Grid.Column="2"
                              Margin="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center">
                            <Ellipse Fill="{StaticResource MilLampBezelBrush}" />
                            <Ellipse Margin="2" Fill="{Binding ClientCoalitionColour}" />
                            <Ellipse Margin="2" Fill="{StaticResource MilLampGlassBrush}" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
    </GroupBox>

</controls:MetroWindow>
