<controls:MetroWindow x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:clientWindow="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:local="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:settings="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.Settings"
                      xmlns:converters="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.Utils.ValueConverters"
                      Title="IL2-SRS Client"
                      Width="700"
                      MinWidth="640"
                      Height="650"
                      MinHeight="560"
                      Background="{StaticResource MilWindowBackgroundBrush}"
                      Foreground="{StaticResource MilTextPrimaryBrush}"
                      FontSize="14"
                      WindowTitleBrush="{StaticResource MilChromeBrush}"
                      NonActiveWindowTitleBrush="{StaticResource MilChromeBrush}"
                      GlowBrush="{StaticResource MilBorderBrush}"
                      NonActiveGlowBrush="{StaticResource MilChromeBrush}"
                      TitleCharacterCasing="Upper"
                      d:DataContext="{d:DesignInstance local:MainWindow}"
                      ResizeMode="CanResizeWithGrip"
                      mc:Ignorable="d">

    <controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IL2-SR-ClientRadio;component/Themes/MilitaryControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:MicAvailabilityTooltipConverter x:Key="MicAvailabilityTooltipConverter" />
            <converters:BooleanToLedBrushConverter x:Key="LedBrushConverter" />
        </ResourceDictionary>
    </controls:MetroWindow.Resources>

    <controls:MetroWindow.TitleTemplate>
        <DataTemplate>
            <TextBlock Margin="8,0,8,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource MilFontStencil}"
                       FontSize="17"
                       Text="{Binding Converter={StaticResource MilUpperConverter}}" />
        </DataTemplate>
    </controls:MetroWindow.TitleTemplate>

    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource MilWellBrush}"
                BorderBrush="{StaticResource MilBorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="10,3" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Grid Width="13" Height="13" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource MilLampBezelBrush}" />
                        <Ellipse Margin="2"
                                 Fill="{Binding AudioInput.MicrophoneAvailable, Converter={StaticResource LedBrushConverter}}" />
                        <Ellipse Margin="2" Fill="{StaticResource MilLampGlassBrush}" />
                    </Grid>
                    <Label Content="Mic" Margin="1,0,10,0" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextSecondaryBrush}" />
                    <Grid Width="13" Height="13" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource MilLampBezelBrush}" />
                        <Ellipse Margin="2"
                                 Fill="{Binding ClientState.IsConnected, Converter={StaticResource LedBrushConverter}}" />
                        <Ellipse Margin="2" Fill="{StaticResource MilLampGlassBrush}" />
                    </Grid>
                    <Label Content="Server" Margin="1,0,10,0" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextSecondaryBrush}" />
                    <Grid Width="13" Height="13" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource MilLampBezelBrush}" />
                        <Ellipse Margin="2"
                                 Fill="{Binding ClientState.IsVoipConnected, Converter={StaticResource LedBrushConverter}}" />
                        <Ellipse Margin="2" Fill="{StaticResource MilLampGlassBrush}" />
                    </Grid>
                    <Label Content="VOIP" Margin="1,0,10,0" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextSecondaryBrush}" />
                    <Grid Width="13" Height="13" VerticalAlignment="Center">
                        <Ellipse Fill="{StaticResource MilLampBezelBrush}" />
                        <Ellipse Margin="2"
                                 Fill="{Binding ClientState.IsGameConnected, Converter={StaticResource LedBrushConverter}}" />
                        <Ellipse Margin="2" Fill="{StaticResource MilLampGlassBrush}" />
                    </Grid>
                    <Label Content="Il-2" Margin="1,0,0,0" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextSecondaryBrush}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Label Content="Connected Clients:" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextSecondaryBrush}" />
                    <TextBlock Text="{Binding Clients.Total}" VerticalAlignment="Center"
                               FontFamily="{StaticResource MilFontMono}" FontSize="13"
                               Foreground="{StaticResource MilTextPrimaryBrush}" />
                    <TextBlock Text="  |  " VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource MilBorderBrush}" />
                    <Label Name="CurrentProfile" Content="None" Padding="2,0"
                           FontFamily="{StaticResource MilFontMono}" FontSize="13"
                           Foreground="{StaticResource MilTextPrimaryBrush}" />
                    <TextBlock Text="  |  " VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource MilBorderBrush}" />
                    <TextBlock x:Name="StatusVersionLabel" VerticalAlignment="Center"
                               FontFamily="{StaticResource MilFontMono}" FontSize="13"
                               Foreground="{StaticResource MilTextSecondaryBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl x:Name="TabControl">
        <TabItem Header="General">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Server">
                            <StackPanel HorizontalAlignment="Center">
                                <ComboBox x:Name="ServerAddressPicker"
                                          Width="220"
                                          Height="28"
                                          Margin="0,8,0,8"
                                          DisplayMemberPath="Name"
                                          ItemsSource="{Binding Path=FavouriteServersViewModel.Addresses}"
                                          SelectedItem="{Binding Path=ServerAddress}" />
                                <TextBox x:Name="ServerIp"
                                         Width="220"
                                         Height="28"
                                         Margin="0,0,0,8"
                                         MaxLines="1"
                                         Text="127.0.0.1:6002"
                                         TextWrapping="Wrap" />
                                <Button x:Name="StartStop"
                                        Width="220"
                                        Margin="0,0,0,8"
                                        Command="{Binding Path=ConnectCommand}"
                                        Content="Connect"
                                        Style="{DynamicResource SquareButtonStyle}"
                                        ToolTip="{Binding Path=AudioInput.MicrophoneAvailable, Converter={StaticResource MicAvailabilityTooltipConverter}}" />
                                <Button x:Name="ToggleServerSettings"
                                        Width="220"
                                        Click="ToggleServerSettings_OnClick"
                                        Content="Show Server Settings"
                                        IsEnabled="False"
                                        Style="{DynamicResource SquareButtonStyle}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="Overlays">
                        <StackPanel HorizontalAlignment="Center">
                            <Button x:Name="ShowOverlay"
                                    Width="220"
                                    Margin="0,8,0,8"
                                    Click="ShowOverlay_OnClick"
                                    Content="Toggle Radio Overlay"
                                    Style="{DynamicResource SquareButtonStyle}" />
                            <Button x:Name="ShowClientList"
                                    Width="220"
                                    Margin="0,0,0,8"
                                    Click="ShowClientList_OnClick"
                                    Content="Toggle Client List"
                                    Style="{DynamicResource SquareButtonStyle}" />
                            <Button x:Name="ShowPilotRoster"
                                    Width="220"
                                    Margin="0,0,0,8"
                                    Click="ShowPilotRoster_OnClick"
                                    Content="Toggle Pilot Roster"
                                    Style="{DynamicResource SquareButtonStyle}" />
                            <StackPanel x:Name="RciStatusPanel"
                                        Margin="0,4,0,5"
                                        HorizontalAlignment="Center"
                                        Visibility="Collapsed">
                                <Grid Width="190"
                                      Height="18">
                                    <Border x:Name="RciStatusIndicator"
                                            Background="#444"
                                            BorderBrush="#666"
                                            BorderThickness="1" />
                                    <TextBlock x:Name="RciStatusLabel"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Courier New"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#E7E7E7"
                                               Text="RCI" />
                                </Grid>
                                <TextBlock x:Name="RciCallsignLabel"
                                           Width="190"
                                           Margin="0,2,0,0"
                                           HorizontalAlignment="Center"
                                           FontFamily="Courier New"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </StackPanel>
                        </GroupBox>
                    </Grid>
                    <GroupBox Header="Favourites">
                        <clientWindow:FavouriteServersView DataContext="{Binding Path=FavouriteServersViewModel}" MaxHeight="230" />
                    </GroupBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Microphone">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="Mic"
                                          Grid.Column="0"
                                          Margin="0,0,14,0"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Top"
                                          ItemsSource="{Binding Path=AudioInput.InputAudioDevices}"
                                          SelectedItem="{Binding Path=AudioInput.SelectedAudioInput, Mode=TwoWay}"
                                          ToolTip="{Binding Path=AudioInput.MicrophoneAvailable, Converter={StaticResource MicAvailabilityTooltipConverter}}" />
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <ProgressBar Name="Mic_VU"
                                                 Width="150"
                                                 Height="80"
                                                 Value="-100"
                                                 Maximum="18"
                                                 Minimum="-100"
                                                 ToolTip="{Binding Path=AudioInput.MicrophoneAvailable, Converter={StaticResource MicAvailabilityTooltipConverter}}" />
                                    <Button x:Name="Preview"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Center"
                                            Click="PreviewAudio"
                                            Content="Audio Preview"
                                            Style="{DynamicResource SquareButtonStyle}"
                                            ToolTipService.ShowOnDisabled="True"
                                            IsEnabled="{Binding AudioInput.MicrophoneAvailable}"
                                            ToolTip="{Binding Path=AudioInput.MicrophoneAvailable, Converter={StaticResource MicAvailabilityTooltipConverter}}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="Speakers &amp; Optional Mic Output">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Top">
                                    <ComboBox x:Name="Speakers"
                                              Margin="0,0,0,10"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Path=AudioOutput.OutputAudioDevices}"
                                              SelectedItem="{Binding Path=AudioOutput.SelectedAudioOutput, Mode=TwoWay}" />
                                    <ComboBox x:Name="MicOutput"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding Path=AudioOutput.MicOutputAudioDevices}"
                                              SelectedItem="{Binding Path=AudioOutput.SelectedMicAudioOutput, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <ProgressBar Name="Speaker_VU"
                                                 Width="150"
                                                 Height="80"
                                                 Value="-100"
                                                 Maximum="18"
                                                 Minimum="-100" />
                                    <Slider x:Name="SpeakerBoost"
                                            Width="150"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Center"
                                            Maximum="1.0"
                                            Minimum="0.0"
                                            IsMoveToPointEnabled="true"
                                            ValueChanged="SpeakerBoost_ValueChanged" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Label Content="Speaker Boost:" />
                                        <Label x:Name="SpeakerBoostLabel" Content="+/- %" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Controls">
            <GroupBox x:Name="ControlsGroupBox" Header="Controls">

                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible">
                    <StackPanel HorizontalAlignment="Center">
                        <Button Width="240"
                                Content="Rescan Input Devices"
                                Click="RescanInputDevices" />
                        <Grid Width="610">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="75" />
                                <ColumnDefinition Width="75" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label x:Name="DeviceLabel"
                               Grid.Row="0"
                               Grid.Column="1"
                               Padding="4,0,4,0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Device" />
                            <Label x:Name="ButtonLabel"
                               Grid.Row="0"
                               Grid.Column="2"
                               Padding="4,0,4,0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Button" />

                            <local:InputBindingControl x:Name="Radio1"
                                                   Grid.Row="1"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.Switch1}"
                                                   InputName="Select First Radio" />
                            <local:InputBindingControl x:Name="Radio2"
                                                       Grid.Row="2"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.Switch2}"
                                                       InputName="Select Second Radio" />
                            <local:InputBindingControl x:Name="PTT"
                                                   Grid.Row="3"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.Ptt}"
                                                   InputName="Common PTT" />
                            <local:InputBindingControl x:Name="Intercom"
                                                   Grid.Row="4"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.Intercom}"
                                                   InputName="Select Intercom" />

                            <local:InputBindingControl x:Name="RadioOverlay"
                                                   Grid.Row="5"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.OverlayToggle}"
                                                   InputName="Overlay Toggle" />

                            <local:InputBindingControl x:Name="RadioChannelUp"
                                                   Grid.Row="6"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.RadioChannelUp}"
                                                   InputName="Radio Channel Up" />

                            <local:InputBindingControl x:Name="RadioChannelDown"
                                                   Grid.Row="7"
                                                   Grid.ColumnSpan="5"
                                                   ControlInputBinding="{x:Static settings:InputBinding.RadioChannelDown}"
                                                   InputName="Radio Channel Down" />
                            <local:InputBindingControl x:Name="RadioChannel1"
                                                       Grid.Row="8"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel1}"
                                                       InputName="Radio Channel 1" />
                            <local:InputBindingControl x:Name="RadioChannel2"
                                                       Grid.Row="9"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel2}"
                                                       InputName="Radio Channel 2" />
                            <local:InputBindingControl x:Name="RadioChannel3"
                                                       Grid.Row="10"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel3}"
                                                       InputName="Radio Channel 3" />
                            <local:InputBindingControl x:Name="RadioChannel4"
                                                       Grid.Row="11"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel4}"
                                                       InputName="Radio Channel 4" />

                            <local:InputBindingControl x:Name="RadioChannel5"
                                                       Grid.Row="12"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel5}"
                                                       InputName="Radio Channel 5" />

                            <local:InputBindingControl x:Name="RadioChannel6"
                                                       Grid.Row="13"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel6}"
                                                       InputName="Radio Channel 6" />

                            <local:InputBindingControl x:Name="RadioChannel7"
                                                       Grid.Row="14"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel7}"
                                                       InputName="Radio Channel 7" />

                            <local:InputBindingControl x:Name="RadioChannel8"
                                                       Grid.Row="15"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel8}"
                                                       InputName="Radio Channel 8" />

                            <local:InputBindingControl x:Name="RadioChannel9"
                                                       Grid.Row="16"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel9}"
                                                       InputName="Radio Channel 9" />

                            <local:InputBindingControl x:Name="RadioChannel10"
                                                       Grid.Row="17"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel10}"
                                                       InputName="Radio Channel 10" />

                            <local:InputBindingControl x:Name="RadioChannel11"
                                                       Grid.Row="18"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel11}"
                                                       InputName="Radio Channel 11" />

                            <local:InputBindingControl x:Name="RadioChannel12"
                                                       Grid.Row="19"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.RadioChannel12}"
                                                       InputName="Radio Channel 12" />

                            <local:InputBindingControl x:Name="NextRadio"
                                                       Grid.Row="20"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.NextRadio}"
                                                       InputName="Select Next Radio" />

                            <local:InputBindingControl x:Name="PreviousRadio"
                                                       Grid.Row="21"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.PreviousRadio}"
                                                       InputName="Select Previous Radio" />

                            <local:InputBindingControl x:Name="ReadStatus"
                                                       Grid.Row="22"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.ReadStatus}"
                                                       InputName="Read Status (TTS on required)" />
                            <local:InputBindingControl x:Name="ToggleSelectedRadioMute"
                                                       Grid.Row="23"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.ToggleSelectedRadioMute}"
                                                       InputName="Mute / Unmute Selected Radio" />
                            <local:InputBindingControl x:Name="ToggleOtherRadioMute"
                                                       Grid.Row="24"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.ToggleOtherRadioMute}"
                                                       InputName="Mute / Unmute Other Radio" />
                            <local:InputBindingControl x:Name="ToggleAllRadiosMute"
                                                       Grid.Row="25"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.ToggleAllRadiosMute}"
                                                       InputName="Mute / Unmute Both Radios" />
                            <local:InputBindingControl x:Name="ToggleMicrophoneMute"
                                                       Grid.Row="26"
                                                       Grid.ColumnSpan="5"
                                                       ControlInputBinding="{x:Static settings:InputBinding.ToggleMicrophoneMute}"
                                                       InputName="Mute / Unmute Microphone" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

            </GroupBox>

        </TabItem>

        <TabItem Header="Settings">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                <StackPanel Margin="10,0,10,0">
                    <GroupBox Header="Global Settings">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="390" />
                                <ColumnDefinition />

                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0"
                               Grid.Column="0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Auto Connect Prompt" />

                            <ToggleButton Name="AutoConnectPromptToggle"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Click="AutoConnectPromptToggle_Click">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Content" Value="ON" />
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="ON" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter Property="Content" Value="OFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>


                            <Label Grid.Row="1"
                               Grid.Column="0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Auto Connect Mismatch Prompt" />

                            <ToggleButton Name="AutoConnectMismatchPromptToggle"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Click="AutoConnectMismatchPromptToggle_Click">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Content" Value="ON" />
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="ON" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter Property="Content" Value="OFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <Label Grid.Row="2"
                               Grid.Column="0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Reset Radio Overlay" />

                            <Button Grid.Row="2"
                                Grid.Column="1"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="ResetRadioWindow_Click"
                                Content="Reset" />


                            <Label Grid.Row="3"
                               Grid.Column="0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Hide Overlay Taskbar Item" />

                            <ToggleButton Name="RadioOverlayTaskbarItem"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Click="RadioOverlayTaskbarItem_Click">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Content" Value="ON" />
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="ON" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter Property="Content" Value="OFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>


                            <Label Grid.Row="4"
                               Grid.Column="0"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="Auto Start Radio Overlay" />

                            <ToggleButton Name="AutoStartRadioOverlayToggle"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Click="AutoStartRadioOverlayToggle_Click">
                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Content" Value="ON" />
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
