<controls:MetroWindow x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.PilotRoster.PilotRosterWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Name="PilotRosterWin"
                      Title="IL2-SRS Pilot Roster"
                      MinWidth="460"
                      MinHeight="125"
                      Width="560"
                      Height="420"
                      ShowInTaskbar="True"
                      ShowTitleBar="False"
                      ShowMinButton="False"
                      ShowMaxRestoreButton="False"
                      ShowCloseButton="False"
                      WindowStyle="None"
                      AllowsTransparency="False"
                      ResizeMode="CanResizeWithGrip"
                      Background="#242820">
    <controls:MetroWindow.Resources>
        <Style x:Key="RosterCellTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F1E6BD" />
            <Setter Property="FontFamily" Value="pack://application:,,,/IL2-SR-ClientRadio;component/Fonts/#Just Another Hand" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Margin" Value="6,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#9D8A55" />
            <Setter Property="Foreground" Value="#1C1F18" />
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="#292D23" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="#303529" />
            <Setter Property="BorderBrush" Value="#4B513F" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="#F1E6BD" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#292D23" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3C422F" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4A432A" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" />
            <Setter Property="Foreground" Value="#F1E6BD" />
            <Setter Property="BorderBrush" Value="#444B3A" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4A432A" />
                    <Setter Property="Foreground" Value="#FFF5CC" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </controls:MetroWindow.Resources>

    <Grid ClipToBounds="True">
    <Border x:Name="RosterFrame"
            Margin="0"
            Background="#303529"
            BorderBrush="#9D8A55"
            BorderThickness="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            MouseLeftButtonDown="RosterFrame_MouseLeftButtonDown">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="PilotList"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      RowHeight="31"
                      ColumnHeaderHeight="30"
                      AlternationCount="2"
                      RowBackground="#303529"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="#292D23"
                      BorderBrush="#151711"
                      BorderThickness="1"
                      AlternatingRowBackground="#292D23">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="CallsignColumn"
                                        Header="CALLSIGN"
                                        Binding="{Binding Callsign}"
                                        Width="Auto"
                                        MinWidth="120"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="PilotColumn"
                                        Header="PILOT"
                                        Binding="{Binding PilotName}"
                                        Width="*"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="Radio1Column"
                                        Header="R1"
                                        Binding="{Binding Radio1Channel}"
                                        Width="Auto"
                                        MinWidth="64"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="Radio2Column"
                                        Header="R2"
                                        Binding="{Binding Radio2Channel}"
                                        Width="Auto"
                                        MinWidth="64"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="UnavailableMessage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="420"
                       Margin="18"
                       Foreground="#F1E6BD"
                       FontFamily="Courier New"
                       FontSize="18"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </Grid>
    </Border>
    </Grid>
</controls:MetroWindow>
