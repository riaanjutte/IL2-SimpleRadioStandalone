<Window x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.PilotRoster.PilotRosterWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:utils="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.Utils"
                      Name="PilotRosterWin"
                      Title="IL2-SRS Pilot Roster"
                      MinWidth="460"
                      MinHeight="90"
                      Width="560"
                      Height="420"
                      ShowInTaskbar="True"
                      WindowStyle="None"
                      AllowsTransparency="True"
                      ResizeMode="CanResizeWithGrip"
                      Background="Transparent">
    <Window.Resources>
        <ControlTemplate x:Key="PilotRosterPanelScrew" TargetType="{x:Type Control}">
            <Grid Width="10.125" Height="10.125">
                <Ellipse Fill="{DynamicResource MilScrewBrush}"
                         Stroke="#15100A"
                         StrokeThickness="0.9" />
                <Rectangle Width="7.3125"
                           Height="1.35"
                           Fill="#241F14"
                           RenderTransformOrigin="0.5,0.5"
                           utils:ScrewSlotRandomizer.RandomAngle="True" />
            </Grid>
        </ControlTemplate>

        <Style x:Key="RosterCellTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource MilFontMono}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="6,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource MilActionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource MilFontMono}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource MilWellBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource MilRowAltBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MilBtnDarkHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MilActionBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}}" />
            <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MilBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MilActionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource MilTextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True"
          Background="{DynamicResource MilWindowBackgroundBrush}">
    <Border x:Name="RosterFrame"
            Margin="0"
            Background="{DynamicResource MilPanelFaceBrush}"
            BorderBrush="#15100A"
            BorderThickness="1"
            CornerRadius="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            MouseLeftButtonDown="RosterFrame_MouseLeftButtonDown">
        <Border BorderBrush="{DynamicResource ThreeDSoftHighlightBrush}"
                BorderThickness="1,1,0,0"
                CornerRadius="5">
        <Grid Margin="18,14,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Rectangle RadiusX="5"
                       RadiusY="5"
                       IsHitTestVisible="False"
                       Opacity="{DynamicResource WeatheringOpacity}"
                       utils:PanelWeathering.Enabled="True" />
            <Rectangle RadiusX="5"
                       RadiusY="5"
                       IsHitTestVisible="False"
                       Opacity="{DynamicResource WeatheringExtraOpacity}"
                       utils:PanelWeathering.Enabled="True" />

            <Control Template="{StaticResource PilotRosterPanelScrew}"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="-12,-8,0,0"
                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
            <Control Template="{StaticResource PilotRosterPanelScrew}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-8,-12,0"
                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
            <Control Template="{StaticResource PilotRosterPanelScrew}"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-12,0,0,-8"
                     Opacity="{DynamicResource ThreeDScrewOpacity}" />
            <Control Template="{StaticResource PilotRosterPanelScrew}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,-12,-8"
                     Opacity="{DynamicResource ThreeDScrewOpacity}" />

            <DataGrid x:Name="PilotList"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      RowHeight="31"
                      ColumnHeaderHeight="30"
                      AlternationCount="2"
                      RowBackground="{DynamicResource MilWellBrush}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      Background="{DynamicResource MilWellBrush}"
                      BorderBrush="#15100A"
                      BorderThickness="1"
                      AlternatingRowBackground="{DynamicResource MilRowAltBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="CallsignColumn"
                                        Header="CALLSIGN"
                                        Binding="{Binding Callsign}"
                                        Width="Auto"
                                        MinWidth="120"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="PilotColumn"
                                        Header="PILOT"
                                        Binding="{Binding PilotName}"
                                        Width="*"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="VehicleColumn"
                                        Header="VEHICLE"
                                        Binding="{Binding Vehicle}"
                                        Width="Auto"
                                        MinWidth="96"
                                        Visibility="Collapsed"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="Radio1Column"
                                        Header="R1"
                                        Binding="{Binding Radio1Channel}"
                                        Width="Auto"
                                        MinWidth="64"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                    <DataGridTextColumn x:Name="Radio2Column"
                                        Header="R2"
                                        Binding="{Binding Radio2Channel}"
                                        Width="Auto"
                                        MinWidth="64"
                                        ElementStyle="{StaticResource RosterCellTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="UnavailableMessage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="420"
                       Margin="18"
                       Foreground="{DynamicResource MilTextPrimaryBrush}"
                       FontFamily="{StaticResource MilFontMono}"
                       FontSize="18"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </Grid>
        </Border>
    </Border>
    </Grid>
</Window>
