<controls:MetroWindow x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ServerSettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      Title="Server Settings"
                      Width="390"
                      Height="360"
                      ResizeMode="NoResize"
                      Background="{StaticResource MilWindowBackgroundBrush}"
                      Foreground="{StaticResource MilTextPrimaryBrush}"
                      FontSize="14"
                      WindowTitleBrush="{StaticResource MilChromeBrush}"
                      NonActiveWindowTitleBrush="{StaticResource MilChromeBrush}"
                      GlowBrush="{StaticResource MilBorderBrush}"
                      NonActiveGlowBrush="{StaticResource MilChromeBrush}"
                      TitleCharacterCasing="Upper">
    <controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IL2-SR-ClientRadio;component/Themes/MilitaryControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:MetroWindow.Resources>

    <controls:MetroWindow.TitleTemplate>
        <DataTemplate>
            <TextBlock Margin="8,0,8,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource MilFontStencil}"
                       FontSize="17"
                       Text="{Binding Converter={StaticResource MilUpperConverter}}" />
        </DataTemplate>
    </controls:MetroWindow.TitleTemplate>

    <GroupBox Header="Reported by server" Margin="6,2,6,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>
            <Label Grid.Row="0"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Coalition Security" />

            <Label Name="CoalitionSecurity"
                   Grid.Row="0"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Label Grid.Row="1"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Spectator Audio" />

            <Label Name="SpectatorAudio"
                   Grid.Row="1"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />
            <Label Grid.Row="2"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="IRL Radio Tx Behaviour" />

            <Label Name="RealRadio"
                   Grid.Row="2"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />


            <Label Grid.Row="3"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Show Tuned Client Count" />

            <Label Name="TunedClientCount"
                   Grid.Row="3"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Label Grid.Row="4"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Show Transmitter Name" />

            <Label Name="ShowTransmitterName"
                   Grid.Row="4"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Label Grid.Row="5"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Server Version" />

            <Label Name="ServerVersion"
                   Grid.Row="5"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Label Grid.Row="6"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Channel Limit" />

            <Label Name="ChannelLimit"
                   Grid.Row="6"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Label Grid.Row="7"
                   Grid.Column="0"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Content="Second Radio Enabled" />

            <Label Name="SecondRadio"
                   Grid.Row="7"
                   Grid.Column="1"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   Foreground="{StaticResource MilAccentBrush}"
                   Content="Unknown" />

            <Button Grid.Row="8"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Width="90"
                    Height="30"
                    Margin="5,4,5,4"
                    VerticalAlignment="Center"
                    Click="CloseButton_OnClick"
                    Content="Close" />


        </Grid>
    </GroupBox>
</controls:MetroWindow>
