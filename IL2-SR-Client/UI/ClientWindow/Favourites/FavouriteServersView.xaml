<UserControl x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.FavouriteServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:clientWindow="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:favourites="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.ClientWindow.Favourites"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI"
             d:DataContext="{d:DesignInstance favourites:FavouriteServersViewModel,
                                              IsDesignTimeCreatable=False}"
             d:DesignHeight="300"
             d:DesignWidth="300"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Add-new-configuration form: label on top, Name and ServerAddress stacked beneath -->
        <Grid Grid.Column="0"
              Margin="0,0,20,0"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Margin="0,0,0,8"
                       HorizontalAlignment="Left"
                       FontWeight="Bold"
                       Text="Add new configuration" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,8,6"
                       VerticalAlignment="Center"
                       Text="Name" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Width="180"
                     Height="28"
                     Margin="0,0,0,6"
                     VerticalContentAlignment="Center"
                     Text="{Binding Path=NewName}" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="ServerAddress" />
            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Width="180"
                     Height="28"
                     VerticalContentAlignment="Center"
                     Text="{Binding Path=NewAddress}" />
            <Button Grid.Row="3"
                    Grid.Column="1"
                    Width="22"
                    Height="20"
                    Margin="0,6,0,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Command="{Binding Path=NewAddressCommand}"
                    ToolTip="Add this server">
                <Path Width="9"
                      Height="9"
                      Data="M 4,0 L 4,8 M 0,4 L 8,4"
                      Stretch="Uniform"
                      Stroke="{StaticResource MilLedOnBrush}"
                      StrokeThickness="1.5" />
            </Button>
        </Grid>

        <DataGrid Name="FavouritesGrid"
                  Grid.Column="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Path=Addresses}"
                  SelectedItem="{Binding Path=SelectedItem}">
            <DataGrid.Resources>
                <Style x:Key="FavouriteServerTextCellStyle" TargetType="{x:Type TextBlock}">
                    <Setter Property="Margin" Value="10,0,6,0" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Name"                                        Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource FavouriteServerTextCellStyle}"
                                       Text="{Binding Path=Name}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="ServerAddress/port"                                        Width="1.4*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource FavouriteServerTextCellStyle}"
                                       Text="{Binding Path=Address}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Default"                                        Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="ui:ServerAddress">

                            <Button Name="Button"
                                    Command="{Binding ElementName=FavouritesGrid,
                                                      Path=DataContext.OnDefaultChangedCommand}"
                                    CommandParameter="{Binding}"
                                    Margin="10,1,6,1"
                                    Padding="0" />

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Path=IsDefault}" Value="True">
                                    <DataTrigger.Setters>
                                        <Setter TargetName="Button" Property="Content">
                                            <Setter.Value>
                                                <Path Height="15"
                                                      Data="F1 M 5.33334,3.05176e-005C 8.27869,3.05176e-005 10.6667,2.38669 10.6667,5.33334L 10.6667,128C 10.6667,130.947 8.27869,133.333 5.33334,133.333C 2.38669,133.333 0,130.947 0,128L 0,5.33334C 0,2.38669 2.38669,3.05176e-005 5.33334,3.05176e-005 Z M 58.4986,3.84378C 65.2643,6.4642 70.6588,8.52805 80,4.45712L 80,44.6909C 70.2527,48.5827 64.0612,46.1921 57.5364,43.664C 52.8828,41.8627 48.0729,40 41.3333,40C 27.6667,40 17.9681,48.1263 16,49.9122L 16,9.08273C 20.028,5.89725 29.1282,3.05176e-005 41.3333,3.05176e-005C 48.5703,3.05176e-005 53.845,2.04163 58.4986,3.84378 Z "
                                                      Fill="{StaticResource MilTextPrimaryBrush}"
                                                      Stretch="Uniform" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger.Setters>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Width="22"
                                    Height="20"
                                    Margin="6,1"
                                    Padding="0"
                                    Command="{Binding ElementName=FavouritesGrid,
                                                      Path=DataContext.RemoveServerCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Remove this server">
                                <Path Width="9"
                                      Height="9"
                                      Data="M 0,0 L 8,8 M 8,0 L 0,8"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource MilLedErrorBrush}"
                                      StrokeThickness="1.5" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</UserControl>
