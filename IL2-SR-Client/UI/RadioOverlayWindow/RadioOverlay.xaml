<Window x:Class="Ciribob.IL2.SimpleRadio.Standalone.Overlay.RadioOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Overlay"
        xmlns:radioOverlayWindow="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.RadioOverlayWindow"
        Name="RadioOverlayWin"
        Title="IL2-SimpleRadio"
        Width="152"
        Height="186"
        MinWidth="152"
        MinHeight="186"
        AllowsTransparency="True"
        Background="#23261F"
        LocationChanged="RadioOverlayWindow_OnLocationChanged"
        Opacity="1.0"
        ResizeMode="CanResizeWithGrip"
        Style="{x:Null}"
        Topmost="True"
        WindowStyle="None">

    <Grid Background="#23261F">
    <WrapPanel Name="ContainerPanel"
               Style="{x:Null}">

        <WrapPanel.RenderTransform>
            <ScaleTransform x:Name="ApplicationScaleTransform"
                             CenterX="0"
                             CenterY="0"
                            ScaleX="{Binding ElementName=RadioOverlayWin,
                                              Path=ScaleValue}"
                             ScaleY="{Binding ElementName=RadioOverlayWin,
                                              Path=ScaleValue}" />
        </WrapPanel.RenderTransform>
        <StackPanel x:Name="SectionsPanel"
                    Orientation="Vertical"
                    Background="Transparent">

        <!-- Plate 1: assigned callsign + Radio 1 -->
        <ContentControl Style="{StaticResource OverlayPlate}">
            <StackPanel Orientation="Vertical">
                <Border x:Name="AssignedCallsignPanel"
                        Width="122"
                        Height="14"
                        Margin="0,0,0,2"
                        HorizontalAlignment="Center"
                        Background="{StaticResource OverlayDisplayBrush}"
                        BorderBrush="#242824"
                        BorderThickness="1"
                        Style="{x:Null}"
                        Visibility="Collapsed">
                    <Grid ClipToBounds="True">
                        <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                                Opacity="0.55"
                                Style="{x:Null}" />
                        <Border Height="5"
                                VerticalAlignment="Top"
                                Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                                Opacity="0.65"
                                Style="{x:Null}" />
                        <Canvas x:Name="AssignedCallsignViewport"
                                ClipToBounds="True">
                            <TextBlock x:Name="AssignedCallsignLabel"
                                       Canvas.Left="0"
                                       Background="Transparent"
                                       FontFamily="Courier New"
                                       FontSize="8"
                                       Foreground="#00FF00"
                                       Style="{x:Null}"
                                       TextAlignment="Center" />
                        </Canvas>
                    </Grid>
                </Border>
                <radioOverlayWindow:RadioControlGroup x:Name="Radio1" RadioId="1" />
            </StackPanel>
        </ContentControl>

        <!-- Plate 2: Radio 2 (shown when a second radio is available) -->
        <ContentControl x:Name="Radio2Plate"
                        Style="{StaticResource OverlayPlate}"
                        Visibility="{Binding ElementName=Radio2, Path=Visibility}">
            <radioOverlayWindow:RadioControlGroup x:Name="Radio2" RadioId="2" Visibility="Collapsed" />
        </ContentControl>

        <!-- Plate 3: Intercom -->
        <ContentControl Style="{StaticResource OverlayPlate}">
            <local:IntercomControlGroup x:Name="Intercom" RadioId="0" />
        </ContentControl>

        <!-- Plate 4: RCI status + window opacity -->
        <ContentControl Style="{StaticResource OverlayPlate}">
            <StackPanel Orientation="Vertical">
                <StackPanel x:Name="RciStatusPanel"
                            Width="122"
                            HorizontalAlignment="Center"
                            MouseLeftButtonDown="RciStatusPanel_MouseLeftButtonDown"
                            Visibility="Collapsed">
                    <Border Height="14"
                            Background="{StaticResource OverlayDisplayBrush}"
                            BorderBrush="#242824"
                            BorderThickness="1"
                            Style="{x:Null}">
                        <Grid ClipToBounds="True">
                            <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                                    Opacity="0.55"
                                    Style="{x:Null}" />
                            <Border Height="5"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                                    Opacity="0.65"
                                    Style="{x:Null}" />
                            <Border x:Name="RciStatusIndicator"
                                    Background="Transparent"
                                    Style="{x:Null}" />
                            <TextBlock x:Name="RciStatusLabel"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Courier New"
                                       FontSize="7"
                                       FontWeight="Bold"
                                       Foreground="#E7E7E7"
                                       Style="{x:Null}"
                                       Text="RCI" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="RciCallsignLabel"
                               Width="122"
                               Height="9"
                               Margin="0,1,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="Courier New"
                               FontSize="7"
                               FontWeight="Bold"
                               Foreground="#E7E7E7"
                               Style="{x:Null}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Visibility="Collapsed" />
                </StackPanel>

                <Slider Margin="0,3,0,0" x:Name="WindowOpacitySlider"
                        Width="122"
                        Height="18"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Style="{StaticResource OverlaySlider}"
                        Maximum="1.0"
                        Minimum="0.05"
                        ToolTip="Window Opacity"
                        ValueChanged="windowOpacitySlider_ValueChanged"
                        Value="1.0" />
            </StackPanel>
        </ContentControl>
        </StackPanel>
    </WrapPanel>
    </Grid>
</Window>
