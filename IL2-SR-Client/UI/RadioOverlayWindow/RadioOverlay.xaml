<Window x:Class="Ciribob.IL2.SimpleRadio.Standalone.Overlay.RadioOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Overlay"
        xmlns:radioOverlayWindow="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Client.UI.RadioOverlayWindow"
        Name="RadioOverlayWin"
        Title="IL2-SimpleRadio"
        Width="130"
        Height="143"
        MinWidth="130"
        MinHeight="143"
        AllowsTransparency="True"
        Background="{StaticResource OverlayEquipmentPanelBrush}"
        LocationChanged="RadioOverlayWindow_OnLocationChanged"
        Opacity="1.0"
        ResizeMode="CanResizeWithGrip"
        Style="{x:Null}"
        Topmost="True"
        WindowStyle="None">

    <Grid Background="{StaticResource OverlayEquipmentPanelBrush}">
    <WrapPanel Name="ContainerPanel"
               Style="{x:Null}">

        <WrapPanel.RenderTransform>
            <ScaleTransform x:Name="ApplicationScaleTransform"
                             CenterX="0"
                             CenterY="0"
                            ScaleX="{Binding ElementName=RadioOverlayWin,
                                              Path=ScaleValue}"
                             ScaleY="{Binding ElementName=RadioOverlayWin,
                                              Path=ScaleValue}" />
        </WrapPanel.RenderTransform>
        <StackPanel Orientation="Vertical"
                    Background="{StaticResource OverlayEquipmentPanelBrush}">

        <Border x:Name="AssignedCallsignPanel"
                Width="122"
                Height="14"
                Margin="4,4,0,2"
                HorizontalAlignment="Left"
                Background="{StaticResource OverlayDisplayBrush}"
                BorderBrush="#242824"
                BorderThickness="1"
                Style="{x:Null}"
                Visibility="Collapsed">
            <Grid ClipToBounds="True">
                <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                        Opacity="0.55"
                        Style="{x:Null}" />
                <Border Height="5"
                        VerticalAlignment="Top"
                        Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                        Opacity="0.65"
                        Style="{x:Null}" />
                <Canvas x:Name="AssignedCallsignViewport"
                        ClipToBounds="True">
                    <TextBlock x:Name="AssignedCallsignLabel"
                               Canvas.Left="0"
                               Background="Transparent"
                               FontFamily="Courier New"
                               FontSize="8"
                               Foreground="#00FF00"
                               Style="{x:Null}"
                               TextAlignment="Center" />
                </Canvas>
            </Grid>
        </Border>

        <radioOverlayWindow:RadioControlGroup x:Name="Radio1" RadioId="1" />
        <Separator Width="130" Margin="0 2" />
        
        <radioOverlayWindow:RadioControlGroup x:Name="Radio2" RadioId="2" Visibility="Collapsed" />
            <Separator Name="Radio2Seperator" Width="130" Margin="0 2" Visibility="Collapsed" />

        <local:IntercomControlGroup x:Name="Intercom" RadioId="0" />
       
        <Separator Width="130" Margin="0 2" />

        <StackPanel x:Name="RciStatusPanel"
                    Width="122"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Left"
                    MouseLeftButtonDown="RciStatusPanel_MouseLeftButtonDown"
                    Visibility="Collapsed">
            <Border Height="14"
                    Background="{StaticResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    Style="{x:Null}">
                <Grid ClipToBounds="True">
                    <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                            Opacity="0.55"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.65"
                            Style="{x:Null}" />
                <Border x:Name="RciStatusIndicator"
                            Background="Transparent"
                            Style="{x:Null}" />
                <TextBlock x:Name="RciStatusLabel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Courier New"
                           FontSize="7"
                           FontWeight="Bold"
                           Foreground="#E7E7E7"
                           Style="{x:Null}"
                           Text="RCI" />
                </Grid>
            </Border>
            <TextBlock x:Name="RciCallsignLabel"
                       Width="122"
                       Height="9"
                       Margin="0,1,0,0"
                       HorizontalAlignment="Center"
                       FontFamily="Courier New"
                       FontSize="7"
                       FontWeight="Bold"
                       Foreground="#E7E7E7"
                       Style="{x:Null}"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed" />
        </StackPanel>

        <Slider Margin="4,3,0,0" x:Name="WindowOpacitySlider"
                Width="122"
                Height="18"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Style="{StaticResource OverlaySlider}"
                Maximum="1.0"
                Minimum="0.05"
                ToolTip="Window Opacity"
                ValueChanged="windowOpacitySlider_ValueChanged"
                Value="1.0" />
        </StackPanel>
    </WrapPanel>
        <Border Background="{StaticResource OverlayWeatheringTexture}"
                IsHitTestVisible="False" />
    </Grid>
</Window>
