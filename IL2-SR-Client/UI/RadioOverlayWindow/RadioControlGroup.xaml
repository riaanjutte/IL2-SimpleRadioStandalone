<UserControl x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.RadioOverlayWindow.RadioControlGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130"
             Height="66">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="OverlayChannelStepButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#8B8E88" Offset="0" />
            <GradientStop Color="#72766F" Offset="0.52" />
            <GradientStop Color="#585D55" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="OverlayChannelButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource OverlayRaisedControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayRaisedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource ButtonForeground}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Style="{x:Null}">
                            <Grid>
                                <Border BorderBrush="{StaticResource OverlayEdgeHighlightBrush}"
                                        BorderThickness="1,1,0,0"
                                        CornerRadius="3"
                                        Opacity="0.35"
                                        Style="{x:Null}" />
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="{StaticResource OverlayPressedControlBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayChannelUpButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource OverlayChannelStepButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayRaisedBorderBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Polygon x:Name="ButtonShape"
                                     Points="1,13 9,1 17,13"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1"
                                     Style="{x:Null}" />
                            <Polyline Points="4,11 9,4 14,11"
                                      Stroke="{StaticResource OverlayEdgeHighlightBrush}"
                                      StrokeThickness="1"
                                      Opacity="0.4"
                                      Style="{x:Null}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource PressedButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource DisabledButtonBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OverlayChannelDownButton"
               BasedOn="{StaticResource OverlayChannelUpButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Polygon x:Name="ButtonShape"
                                     Points="1,1 9,13 17,1"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1"
                                     Style="{x:Null}" />
                            <Polyline Points="4,3 9,10 14,3"
                                      Stroke="{StaticResource OverlayEdgeHighlightBrush}"
                                      StrokeThickness="1"
                                      Opacity="0.4"
                                      Style="{x:Null}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource PressedButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource DisabledButtonBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical"
                Background="{StaticResource OverlayEquipmentPanelBrush}"
                HorizontalAlignment="Center"
                Width="130"
                Style="{x:Null}">

        <Grid HorizontalAlignment="Center" Height="31">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="104" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Width="18"
                  Height="31"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Button x:Name="ChannelUpButton"
                        Width="18"
                        Height="14"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ChannelUp_Click"
                        Style="{StaticResource OverlayChannelUpButton}"
                        ToolTip="Radio Channel Up" />
                <Button x:Name="ChannelDownButton"
                        Width="18"
                        Height="14"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ChannelDown_Click"
                        Style="{StaticResource OverlayChannelDownButton}"
                        ToolTip="Radio Channel Down" />
            </Grid>

            <UniformGrid x:Name="ChannelGrid"
                         Grid.Column="1"
                         Columns="6"
                         Rows="2"
                         Width="104"
                         Height="31"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center" />

        </Grid>

        <Grid Width="122" Height="12" Margin="4,5,0,1" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="25" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="12" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="78"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    MouseDown="RadioFrequencyText_Click">
                <Grid>
                    <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                            Opacity="0.55"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.65"
                            Style="{x:Null}" />
                    <TextBlock x:Name="RadioFrequency"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               FontFamily="Courier New"
                               FontSize="8"
                               Background="Transparent"
                               Foreground="#00FF00"
                               MouseDown="RadioFrequencyText_Click"
                               Style="{x:Null}"
                               Text="CHN 1"
                               TextAlignment="Center"
                               TextWrapping="NoWrap" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Width="25"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    ToolTip="Number of pilots on this channel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="1"
                                      Direction="315"
                                      Opacity="0.25"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Border.Effect>
                <Grid ClipToBounds="True">
                    <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                            Opacity="0.5"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.6"
                            Style="{x:Null}" />
                    <Grid Width="25"
                          Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Style="{x:Null}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UsersLabel"
                                   Grid.Column="0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="4"
                                   FontWeight="Bold"
                                   Foreground="#D8D8D8"
                                   Style="{x:Null}"
                                   Text="PLTS:"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="UsersCount"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="7"
                                   Foreground="#00FF00"
                                   Style="{x:Null}"
                                   Text="0"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Grid>
            </Border>

            <Ellipse x:Name="RadioActive"
                     Grid.Column="4"
                     Width="12"
                     Height="12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Fill="#FF9900"
                     MouseDown="RadioSelectSwitch"
                     Stroke="Black"
                     StrokeThickness="1.5"
                     Style="{x:Null}"
                     ToolTip="Selected Radio">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="2"
                                      Direction="315"
                                      Opacity="0.55"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <Grid Width="122" HorizontalAlignment="Left" Height="17" Margin="4,0,0,0">
            <Slider x:Name="RadioVolume"
                    Width="122"
                    Height="18"
                    Margin="0,0,0,0"
                    Style="{StaticResource OverlaySlider}"
                    VerticalAlignment="Center"
                    IsEnabled="True"
                    Maximum="100"
                    Thumb.DragCompleted="RadioVolume_DragCompleted"
                    Thumb.DragStarted="RadioVolume_DragStarted"
                    ValueChanged="RadioVolume_ValueChanged" />
        </Grid>
    </StackPanel>
</UserControl>
