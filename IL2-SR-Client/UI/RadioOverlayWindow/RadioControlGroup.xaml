<UserControl x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.RadioOverlayWindow.RadioControlGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130"

             Height="70" >

    

    <StackPanel Orientation="Vertical" Background="#444" HorizontalAlignment="Center" Width="130"
                Style="{x:Null}">

        <Grid HorizontalAlignment="Center" Height="31">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="104" />
                <ColumnDefinition Width="18" />
            </Grid.ColumnDefinitions>

            <UniformGrid x:Name="ChannelGrid"
                         Grid.Column="0"
                         Columns="6"
                         Rows="2"
                         Width="102"
                         Height="31"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />

            <Ellipse x:Name="RadioActive"
                     Grid.Column="1"
                     Width="12"
                     Height="12"
                     Margin="2,2,2,0"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Fill="#FF9900"
                     MouseDown="RadioSelectSwitch"
                     Stroke="Black"
                     Style="{x:Null}"
                     ToolTip="Selected Radio" />
        </Grid>
             
                    <TextBlock x:Name="RadioFrequency"
                               Width="118"
                               Height="17"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontFamily="Courier New"
                               Background="Black"
                               Foreground="#00FF00"
                               MouseDown="RadioFrequencyText_Click"
                               Style="{x:Null}"
                               Text="CHN 1"
                               TextAlignment="Center"
                               TextWrapping="NoWrap" Margin="5,2,0,2" />

                <Grid HorizontalAlignment="Center" Height="17" Margin="0,0,0,0">
         
            <Slider x:Name="RadioVolume"
                            Width="80"
                            Height="18"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            IsEnabled="True"
                            Maximum="100"
                            Thumb.DragCompleted="RadioVolume_DragCompleted"
                            Thumb.DragStarted="RadioVolume_DragStarted"  />


                </Grid>
            </StackPanel>
   
</UserControl>
