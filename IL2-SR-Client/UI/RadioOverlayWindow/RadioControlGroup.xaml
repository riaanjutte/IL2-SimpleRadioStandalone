<UserControl x:Class="Ciribob.IL2.SimpleRadio.Standalone.Client.UI.RadioOverlayWindow.RadioControlGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130"
             Height="65">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="OverlayChannelStepButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#8B8E88" Offset="0" />
            <GradientStop Color="#72766F" Offset="0.52" />
            <GradientStop Color="#585D55" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="OverlayChannelStepButtonShadowBrush" Color="#99000000" />

        <Style x:Key="OverlayChannelButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource OverlayRaisedControlBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlayRaisedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource OverlayChannelButtonForegroundBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Style="{x:Null}">
                            <Grid>
                                <Border BorderBrush="{DynamicResource OverlayEdgeHighlightBrush}"
                                        BorderThickness="1,1,0,0"
                                        CornerRadius="3"
                                        Opacity="{DynamicResource ThreeDEffectOpacity}"
                                        Style="{x:Null}" />
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" Value="{DynamicResource OverlayPressedControlBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayChannelUpButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource OverlayAccentRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlayAccentRaisedBorderBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Polygon x:Name="ButtonShape"
                                     Points="1,13 9,1 17,13"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1"
                                     Style="{x:Null}" />
                            <Polyline Points="4,11 9,4 14,11"
                                      Stroke="{DynamicResource OverlayEdgeHighlightBrush}"
                                      StrokeThickness="1"
                                      Opacity="{DynamicResource ThreeDEffectOpacity}"
                                      Style="{x:Null}" />
                            <Line X1="2"
                                  Y1="13"
                                  X2="16"
                                  Y2="13"
                                  Stroke="{StaticResource OverlayChannelStepButtonShadowBrush}"
                                  StrokeThickness="1"
                                  Opacity="{DynamicResource ThreeDEffectOpacity}"
                                  Style="{x:Null}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource PressedButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource DisabledButtonBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OverlayChannelDownButton"
               BasedOn="{StaticResource OverlayChannelUpButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Polygon x:Name="ButtonShape"
                                     Points="1,1 9,13 17,1"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1"
                                     Style="{x:Null}" />
                            <Line X1="2"
                                  Y1="1"
                                  X2="16"
                                  Y2="1"
                                  Stroke="{DynamicResource OverlayEdgeHighlightBrush}"
                                  StrokeThickness="1"
                                  Opacity="{DynamicResource ThreeDEffectOpacity}"
                                  Style="{x:Null}" />
                            <Polyline Points="2,1 9,12 16,1"
                                      Stroke="{StaticResource OverlayChannelStepButtonShadowBrush}"
                                      StrokeThickness="1"
                                      Opacity="{DynamicResource ThreeDEffectOpacity}"
                                      Style="{x:Null}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource MouseOverButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource PressedButtonBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="ButtonShape" Property="Fill" Value="{StaticResource DisabledButtonBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical"
                Background="Transparent"
                HorizontalAlignment="Center"
                Width="130"
                Style="{x:Null}">

        <Grid HorizontalAlignment="Center" Height="31">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="104" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Width="18"
                  Height="31"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Button x:Name="ChannelUpButton"
                        Width="18"
                        Height="14"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ChannelUp_Click"
                        Style="{StaticResource OverlayChannelUpButton}"
                        ToolTip="Radio Channel Up" />
                <Button x:Name="ChannelDownButton"
                        Width="18"
                        Height="14"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ChannelDown_Click"
                        Style="{StaticResource OverlayChannelDownButton}"
                        ToolTip="Radio Channel Down" />
            </Grid>

            <UniformGrid x:Name="ChannelGrid"
                         Grid.Column="1"
                         Columns="6"
                         Rows="2"
                         Width="104"
                         Height="31"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center" />

        </Grid>

        <Grid Width="126" Height="18" Margin="4,3,0,0" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="68" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="25" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="31" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="68"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{DynamicResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    MouseDown="RadioFrequencyText_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="1"
                                      Direction="315"
                                      Opacity="{DynamicResource ThreeDEffectOpacity}"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Border.Effect>
                <Grid x:Name="RadioFrequencyViewport"
                      ClipToBounds="True"
                      MouseDown="RadioFrequencyText_Click">
                    <Border Background="{DynamicResource OverlayDisplayGlassBrush}"
                            Opacity="0.5"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{DynamicResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.6"
                            Style="{x:Null}" />
                    <Canvas x:Name="RadioFrequencyCanvas"
                            ClipToBounds="True"
                            MouseDown="RadioFrequencyText_Click">
                        <TextBlock x:Name="RadioFrequency"
                                   Canvas.Left="0"
                                   Background="Transparent"
                                   FontFamily="Courier New"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="#00FF00"
                                   MouseDown="RadioFrequencyText_Click"
                                   Opacity="1"
                                   Style="{x:Null}"
                                   Text="CHN 1"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap" />
                    </Canvas>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Width="25"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{DynamicResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    ToolTip="Number of pilots on this channel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="1"
                                      Direction="315"
                                      Opacity="{DynamicResource ThreeDEffectOpacity}"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Border.Effect>
                <Grid ClipToBounds="True">
                    <Border Background="{DynamicResource OverlayDisplayGlassBrush}"
                            Opacity="0.5"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{DynamicResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.6"
                            Style="{x:Null}" />
                    <Grid Width="25"
                          Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Style="{x:Null}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="11" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UsersLabel"
                                   Grid.Column="0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="4"
                                   Foreground="#D8D8D8"
                                   Style="{x:Null}"
                                   Text="PLTS:"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="UsersCount"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="7"
                                   Foreground="#00FF00"
                                   Style="{x:Null}"
                                   Text="0"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="4"
                  Width="27"
                  Height="16"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Style="{x:Null}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6" />
                    <RowDefinition Height="10" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="9" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="9" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="9" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Courier New"
                           FontSize="4"
                           Foreground="{DynamicResource OverlayTxRxLabelBrush}"
                           Style="{x:Null}"
                           Text="ACT" />
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Courier New"
                           FontSize="4"
                           Foreground="{DynamicResource OverlayTxRxLabelBrush}"
                           Style="{x:Null}"
                           Text="TX" />
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Courier New"
                           FontSize="4"
                           Foreground="{DynamicResource OverlayTxRxLabelBrush}"
                           Style="{x:Null}"
                           Text="RX" />

                <Ellipse x:Name="RadioSelectedActive"
                         Grid.Row="1"
                         Grid.Column="0"
                         Width="7"
                         Height="7"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="Green"
                         MouseDown="RadioSelectSwitch"
                         Stroke="Black"
                         StrokeThickness="1"
                         Style="{x:Null}"
                         ToolTip="Active radio">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="2"
                                          Direction="315"
                                          Opacity="{DynamicResource ThreeDEffectOpacity}"
                                          ShadowDepth="1"
                                          Color="#000000" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse x:Name="TxActive"
                         Grid.Row="1"
                         Grid.Column="2"
                         Width="7"
                         Height="7"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="Green"
                         MouseDown="RadioSelectSwitch"
                         Stroke="Black"
                         StrokeThickness="1"
                         Style="{x:Null}"
                         ToolTip="Transmit status">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="2"
                                          Direction="315"
                                          Opacity="{DynamicResource ThreeDEffectOpacity}"
                                          ShadowDepth="1"
                                          Color="#000000" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse x:Name="RxActive"
                         Grid.Row="1"
                         Grid.Column="4"
                         Width="7"
                         Height="7"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="Green"
                         MouseDown="RadioSelectSwitch"
                         Stroke="Black"
                         StrokeThickness="1"
                         Style="{x:Null}"
                         ToolTip="Receive status">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="2"
                                          Direction="315"
                                          Opacity="{DynamicResource ThreeDEffectOpacity}"
                                          ShadowDepth="1"
                                          Color="#000000" />
                    </Ellipse.Effect>
                </Ellipse>
            </Grid>
        </Grid>

        <Grid Width="122" HorizontalAlignment="Left" Height="14" Margin="4,0,0,0">
            <Slider x:Name="RadioVolume"
                    Width="122"
                    Height="14"
                    Margin="0,0,0,0"
                    Style="{StaticResource OverlaySlider}"
                    VerticalAlignment="Center"
                    IsEnabled="True"
                    Maximum="100"
                    Thumb.DragCompleted="RadioVolume_DragCompleted"
                    Thumb.DragStarted="RadioVolume_DragStarted"
                    ValueChanged="RadioVolume_ValueChanged" />
        </Grid>
    </StackPanel>
</UserControl>
