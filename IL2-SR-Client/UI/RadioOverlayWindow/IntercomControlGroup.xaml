<UserControl x:Class="Ciribob.IL2.SimpleRadio.Standalone.Overlay.IntercomControlGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ciribob.IL2.SimpleRadio.Standalone.Overlay"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Name="RadioControlContainer"
             Width="130"
             Height="40">
    <StackPanel Orientation="Vertical"
                HorizontalAlignment="Center"
                Width="130"
                Background="{StaticResource OverlayEquipmentPanelBrush}">

        <Grid HorizontalAlignment="Left" Width="122" Height="14" Margin="4,3,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="25" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="12" />
            </Grid.ColumnDefinitions>

            <Label Name="TunedCount" 
                   Grid.Column="0"
                   HorizontalAlignment="Left"
                   FontFamily="Courier New"
                   Content="👤10" Width="30" Margin="0" Padding="0" 
                   Foreground="#E7E7E7" FontSize="12"
                   Visibility="Collapsed" ></Label>


            <Border Grid.Column="0"
                    Width="78"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1">
                <Grid>
                    <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                            Opacity="0.55"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.65"
                            Style="{x:Null}" />
                    <Label x:Name="RadioLabel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Content="INTERCOM"
                           FontFamily="Courier New"
                           FontSize="8"
                           Foreground="#00FF00"
                           Padding="0"
                           Style="{x:Null}" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Width="25"
                    Height="12"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="{StaticResource OverlayDisplayBrush}"
                    BorderBrush="#242824"
                    BorderThickness="1"
                    ToolTip="Number of pilots on this channel">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="1"
                                      Direction="315"
                                      Opacity="0.25"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Border.Effect>
                <Grid ClipToBounds="True">
                    <Border Background="{StaticResource OverlayDisplayGlassBrush}"
                            Opacity="0.5"
                            Style="{x:Null}" />
                    <Border Height="5"
                            VerticalAlignment="Top"
                            Background="{StaticResource OverlayDisplayTopReflectionBrush}"
                            Opacity="0.6"
                            Style="{x:Null}" />
                    <Grid Width="25"
                          Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Style="{x:Null}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="11" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="4"
                                   FontWeight="Bold"
                                   Foreground="#D8D8D8"
                                   Style="{x:Null}"
                                   Text="PLTS:"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="IntercomUsersCount"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="7"
                                   Foreground="#00FF00"
                                   Style="{x:Null}"
                                   Text="0"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap" />
                    </Grid>
                </Grid>
            </Border>

            <Ellipse x:Name="RadioActive"
                      Grid.Column="4"
                      Width="12"
                      Height="12"
                      Margin="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                     Fill="#FF9900"
                      MouseDown="RadioSelectSwitch"
                      Stroke="Black"
                      StrokeThickness="1.5"
                      Style="{x:Null}"
                     ToolTip="Selected Radio">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="2"
                                      Direction="315"
                                      Opacity="0.55"
                                      ShadowDepth="1"
                                      Color="#000000" />
                </Ellipse.Effect>
            </Ellipse>

        </Grid>
       
        
            <Slider x:Name="RadioVolume"
                    Width="122"
                    Height="18"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Left"
                    Style="{StaticResource OverlaySlider}"
                    IsEnabled="True"
                    Maximum="100"
                    ToolTip="Intercom Volume"
                    Thumb.DragCompleted="RadioVolume_DragCompleted"
                    Thumb.DragStarted="RadioVolume_DragStarted"
                    ValueChanged="RadioVolume_ValueChanged" />
        

      

    </StackPanel>
</UserControl>
